          "id": "kA9mS5H3GRsW03H8",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "/**\n * EDNS Risk Event Normalization\n *\n * Purpose:\n * Combine the original RSS signal data with the AI risk analysis result.\n *\n * Input:\n * - AI Risk Analysis output\n * - Original article data from Deduplicate Signals node\n *\n * Output:\n * Normalized risk event records ready for Supabase storage\n */\n\nconst aiItems = $input.all();\nconst sourceItems = $items(\"Deduplicate Signals\");\n\nreturn aiItems.map((item, index) => {\n\n  // Original RSS article\n  const source = sourceItems[index].json;\n\n  // AI response text\n  let aiText = item.json.output[0].content[0].text;\n\n  // Remove markdown code blocks if AI accidentally returns them\n  aiText = aiText\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  // Convert AI JSON text to JavaScript object\n  const risk = JSON.parse(aiText);\n\n  return {\n    json: {\n      source_title: source.title,\n      source_url: source.link,\n      article_date: source.pubDate,\n\n      incident_type: risk.incident_type,\n      severity_score: risk.severity_score,\n      confidence_score: risk.confidence_score,\n\n      reasoning_summary: risk.reasoning_summary,\n      prediction_summary: risk.prediction_summary,\n      recommended_action: risk.recommended_action,\n\n      processed_at: new Date().toISOString()\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
