      "name": "Collect RSS Signals"
    },
    {
      "parameters": {
        "jsCode": "/**\n * EDNS Signal Collector\n * Filter Recent Signals\n *\n * Purpose:\n * Retain only recent RSS articles published within the last 48 hours.\n *\n * Benefits:\n * - Reduces unnecessary AI processing costs\n * - Prevents analysis of stale business signals\n * - Focuses EDNS on current operational events\n *\n * Input:\n * RSS articles from Fetch RSS Feed node\n *\n * Output:\n * Only articles published within the last 48 hours\n */\n\n\n// Calculate cutoff date (Current Time - 48 Hours)\nconst cutoffDate = new Date();\ncutoffDate.setHours(cutoffDate.getHours() - 48);\n\n\n// Retrieve all RSS articles from previous node\nconst inputItems = $input.all();\n\n\n// Filter articles based on publication date\nreturn inputItems.filter(item => {\n\n    // Convert RSS publication date string into JavaScript Date object\n    const articleDate = new Date(item.json.pubDate);\n\n    // Keep only articles published within the last 48 hours\n    return articleDate >= cutoffDate;\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -416,
        -272
      ],
      "id": "e3c20055-ed5e-4801-890c-34dfcb6b7c0b",
      "name": "Filter Recent Signals"
    },
    {
      "parameters": {
        "compare": "selectedFields",
        "fieldsToCompare": "guid",
        "options": {}
      },
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 2,
      "position": [
