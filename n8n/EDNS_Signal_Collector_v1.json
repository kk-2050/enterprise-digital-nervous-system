        },
        "responses": {
          "values": [
            {
              "content": "=Analyze the following business signal.\n\nReturn ONLY valid JSON.\n\n{\n  \"incident_type\": \"\",\n  \"severity_score\": 1,\n  \"confidence_score\": 1,\n  \"reasoning_summary\": \"\",\n  \"prediction_summary\": \"\",\n  \"recommended_action\": \"\"\n}\n\nTitle:\n{{$json.title}}\n\nSummary:\n{{$json.contentSnippet}}\n\nSource:\n{{$json.link}}\n\nScoring Rules\n\nSeverity Score:\n1 = Low\n2 = Minor\n3 = Moderate\n4 = High\n5 = Critical\n\nConfidence Score:\n1 - 10\n\nFocus on:\n\nOperational Risk\nSupply Chain Risk\nFinancial Risk\nTechnology Risk\nCybersecurity Risk\nRegulatory Risk\n\nReturn JSON only."
            },
            {
              "role": "system",
              "content": "You are an Enterprise Risk Intelligence Analyst.\n\nYour job is to evaluate business events and determine their operational impact.\n\nAlways return valid JSON.\n\nNever return markdown.\n\nNever return explanations outside the JSON structure.\n\nThink like:\n\nOperations Manager\nSupply Chain Manager\nBusiness Continuity Manager\nEnterprise Risk Analyst"
            }
          ]
        },
        "simplify": false,
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.3,
      "position": [
